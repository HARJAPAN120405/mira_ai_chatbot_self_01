{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": null,
  "installCommand": "npm install --legacy-peer-deps",
  "rewrites": [
    { "source": "/", "destination": "/panel/src/panel/index.html" },
    { "source": "/panel", "destination": "/panel/src/panel/index.html" }
  ],
  "headers": [
    {
      "source": "/chatbot.min.js",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/panel/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ]
}
